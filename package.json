{
  "name": "print-queue",
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "pnpm oxlint",
    "lint:fix": "pnpm oxlint --fix",
    "fmt": "pnpm oxfmt",
    "fmt:check": "pnpm oxfmt --check",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "check": "pnpm lint && pnpm lint:css && pnpm fmt:check && pnpm build",
    "fix": "pnpm lint:fix && pnpm lint:css:fix && pnpm fmt",
    "bump": "node scripts/bump.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
